# Application Settings
APP_ENV=development
APP_NAME="PHP Light Framework"
API_VERSION=1.0.1
APP_URL=http://localhost


# # API Configuration
# API_BASE_PATH=api

# Monitoring Configuration
ENABLE_MONITORING=true
MAX_MONITORING_VIEWERS=2


# ----- debugging options -------
DEBUG_MODE=true
SHOW_ERRORS=true
LOG_ERRORS=true

# ----- rate limiting settings -------
RATE_LIMIT_REQUESTS=10000000
RATE_LIMIT_WINDOW=1800


# CLI Database (for running PHP from Windows)
DB_HOST_CLI=127.0.0.1
DB_PORT_CLI=3306

# ----- Database Configuration -------
# Development Database
DB_DEV_HOST=localhost
DB_DEV_PORT=3306
DB_DEV_DATABASE=connectping2
DB_DEV_USERNAME=root
DB_DEV_PASSWORD=abcd
DB_DEV_CHARSET=utf8mb4

# Production Database
DB_PROD_HOST=phpmyadmin.coolify.vps.boomlive.in
DB_PROD_PORT=3303
DB_PROD_DATABASE=connectping2
DB_PROD_USERNAME=root
DB_PROD_PASSWORD=abcd
DB_PROD_CHARSET=utf8mb4

# Default Timezone
DB_TIMEZONE=Asia/Kolkata

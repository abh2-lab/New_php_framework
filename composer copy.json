{
    "name": "yourname/php-light-framework",
    "description": "A lightweight PHP API framework",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "src/api/controllers/",
            "App\\Core\\Exceptions\\": "src/api/core/exceptions/",
            "App\\Core\\Utilities\\": "src/api/core/utilities/",
            "App\\Core\\Middleware\\": "src/api/core/middleware/",
            "App\\Core\\": "src/api/core/",
            "App\\Services\\": "src/api/services/",
            "App\\Repositories\\": "src/api/repositories/",
            "App\\": "src/api/"
        },
        "files": [
            "src/api/helpers/_autoload_helpers.php"
        ]
    },
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^6.11",
        "jetbrains/phpstorm-stubs": "^2024.3"
    }
}
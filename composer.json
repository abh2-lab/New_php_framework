{
    "name": "your-name/modern-php-framework",
    "description": "A modular, AI-ready PHP framework with built-in developer tools.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/api/",
            "Framework\\Core\\": "src/api/Core/"
        },
        "files": [
            "src/api/helpers/globalHelpers.php",
            "src/api/helpers/utilityHelpers.php"
        ]
    },
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "config": {
        "optimize-autoloader": true
    }
}
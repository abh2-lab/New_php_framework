{
    "name": "yourname/php-light-framework",
    "description": "A lightweight PHP API framework",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "api/controllers/",
            "App\\Core\\Exceptions\\": "api/core/exceptions/",
            "App\\Core\\Middleware\\": "api/core/middleware/",
            "App\\Core\\": "api/core/",
            "App\\Services\\": "api/services/",
            "App\\": "api/"
        },
        "files": [
            "api/helpers/_autoload_helpers.php"
        ]
    },
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^6.11"
    }
}
